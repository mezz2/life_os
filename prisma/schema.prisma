// LifeOS — Finances schema
// Prisma 7, SQLite. Run: npx prisma migrate dev

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ---------- Accounts ----------

model Account {
  id            String        @id @default(cuid())
  name          String
  institution   String // CBA | Westpac | UBank | Manual
  type          String // transaction | savings | brokerage | super | crypto
  currency      String        @default("AUD")
  createdAt     DateTime      @default(now())
  transactions  Transaction[]
  importBatches ImportBatch[]
}

// ---------- Category taxonomy (3-tier: Category > Subcategory > Line item via name) ----------

model Category {
  id            String        @id @default(cuid())
  name          String        @unique // Income | Needs | Wants | Misc | Transfer | Investment
  kind          String // income | expense | transfer | investment
  sortOrder     Int           @default(0)
  subcategories Subcategory[]
}

model Subcategory {
  id           String         @id @default(cuid())
  name         String
  group        String? // optional mid-tier grouping e.g. "Survival", "Transport", "Eating Out"
  categoryId   String
  category     Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  valueId      String? // which life Value this spending serves (Phase 11 alignment)
  value        Value?         @relation(fields: [valueId], references: [id], onDelete: SetNull)
  sortOrder    Int            @default(0)
  transactions Transaction[]
  rules        CategoryRule[]
  budgetLines  BudgetLine[]

  @@unique([categoryId, name])
  @@index([categoryId])
  @@index([valueId])
}

// ---------- Transactions ----------

model Transaction {
  id             String       @id @default(cuid())
  date           DateTime
  description    String // cleaned/display description
  rawDescription String // original from bank CSV
  amount         Float // signed: negative = money out, positive = money in
  direction      String // debit | credit
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  subcategoryId  String?
  subcategory    Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  source         String       @default("import") // import | manual
  importBatchId  String?
  importBatch    ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  hash           String       @unique // dedupe: account|date|amount|rawDescription
  notes          String?
  needsReview    Boolean      @default(false) // true when auto-categoriser was unsure
  createdAt      DateTime     @default(now())

  @@index([date])
  @@index([accountId])
  @@index([subcategoryId])
}

// ---------- Categorisation rules (learned from manual recategorisation) ----------

model CategoryRule {
  id            String      @id @default(cuid())
  pattern       String // text to match against rawDescription/description
  matchType     String      @default("contains") // contains | equals | regex | startsWith
  subcategoryId String
  subcategory   Subcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  priority      Int         @default(100) // lower = checked first
  source        String      @default("user") // user | seed | ai
  createdAt     DateTime    @default(now())

  @@index([priority])
}

// ---------- Budgets ----------

model BudgetLine {
  id              String      @id @default(cuid())
  subcategoryId   String
  subcategory     Subcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  periodType      String      @default("monthly") // monthly | annual
  projectedAmount Float
  effectiveFrom   DateTime    @default(now())

  @@index([subcategoryId])
}

// ---------- Net worth ----------

model NetWorthSnapshot {
  id      String          @id @default(cuid())
  date    DateTime        @unique
  note    String?
  entries NetWorthEntry[]
}

model NetWorthEntry {
  id         String           @id @default(cuid())
  snapshotId String
  snapshot   NetWorthSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  bucket     String // Emergency Fund | Savings | US Equities | AUS Equities | Global Equities | Crypto | Super
  amount     Float

  @@unique([snapshotId, bucket])
}

// ---------- Values (top of the Atomic Habits hierarchy — Phase 2) ----------

model Value {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "Health", "Financial discipline", "Craft"
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  goals       Goal[]
  habits      Habit[]
  events      CalendarEvent[]
  seasons     Season[]
  references  Reference[]
  subcategories Subcategory[]
  checkins    DailyCheckin[]
}

// ---------- Goals ----------

model Goal {
  id            String    @id @default(cuid())
  name          String
  term          String    @default("short") // short | long
  kind          String    @default("financial") // financial | habit | outcome
  targetAmount  Float?
  currentAmount Float     @default(0)
  targetDate    DateTime?
  linkedBucket  String? // net-worth bucket to auto-read currentAmount from
  notes         String?
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  valueId       String? // the value this goal serves
  value         Value?    @relation(fields: [valueId], references: [id], onDelete: SetNull)
  habits        Habit[] // leading-indicator habits for this goal
  events        CalendarEvent[]
  references    Reference[]

  @@index([valueId])
}

// ---------- Imports ----------

model ImportBatch {
  id           String        @id @default(cuid())
  filename     String
  accountId    String
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  importedAt   DateTime      @default(now())
  rowCount     Int           @default(0)
  addedCount   Int           @default(0)
  skippedCount Int           @default(0)
  transactions Transaction[]
}

// ---------- Insights / alerts ----------

model Insight {
  id          String   @id @default(cuid())
  generatedAt DateTime @default(now())
  period      String // e.g. "2026-05" or "rolling"
  type        String // overspend | spike | subscription | savings_rate | goal_pace | yoy | large_txn | narrative
  severity    String   @default("info") // info | warn | alert
  title       String
  body        String
  payload     String? // JSON blob of supporting data
  dismissed   Boolean  @default(false)

  @@index([period])
}

// ---------- Future LifeOS modules (reserved, not built in v1) ----------

model HealthMetric {
  id     String   @id @default(cuid())
  date   DateTime
  metric String
  value  Float
  unit   String?

  @@index([date])
}

// ---------- Daily check-in (energy layer — Phase 3) ----------

model DailyCheckin {
  id           String   @id @default(cuid())
  date         DateTime @unique // UTC midnight, one row per day
  energy       Int // 1-5
  mood         Int // 1-5
  sleepHours   Float?
  note         String?
  focusValueId String? // "where did my time go today?" — manual proxy until GCal is connected
  focusValue   Value?   @relation(fields: [focusValueId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([date])
  @@index([focusValueId])
}

// ---------- Calendar cache (time-allocation lens — Phase 4) ----------
// Local-first mirror of Google Calendar. Synced via /api/calendar/sync (events
// pushed in from the GCal MCP or a script); the app always reads this cache.

model CalendarEvent {
  id         String   @id @default(cuid())
  externalId String?  @unique // GCal event id; null for manually-added events
  calendarId String?
  title      String
  start      DateTime
  end        DateTime
  allDay     Boolean  @default(false)
  rigidity   String   @default("fixed") // fixed | flexible | elastic | fluid (used by Phase 5)
  valueId    String?
  value      Value?   @relation(fields: [valueId], references: [id], onDelete: SetNull)
  goalId     String?
  goal       Goal?    @relation(fields: [goalId], references: [id], onDelete: SetNull)
  raw        String? // original GCal JSON payload
  syncedAt   DateTime @default(now())
  shuffleBatch String? // set when created by an applied shuffle proposal (for undo)

  @@index([start])
  @@index([valueId])
  @@index([shuffleBatch])
}

// ---------- Google Calendar OAuth (write-back) ----------
// Single-row credential store. App credentials (client id/secret) live in .env;
// this holds the user's grant — the offline refresh token plus the latest
// access token/expiry, so the server can act on Google on the user's behalf.
// Local SQLite only; never committed, same trust boundary as .env.

model GoogleCalendarAuth {
  id           String    @id @default("singleton") // enforce one row
  refreshToken String // long-lived offline grant
  accessToken  String? // short-lived; refreshed as needed
  expiry       DateTime? // accessToken expiry
  calendarId   String    @default("primary") // which calendar to sync/write
  email        String? // connected Google account, for display
  connectedAt  DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ---------- Weekly review (Phase 6) ----------

model WeeklyReview {
  id        String   @id @default(cuid())
  weekStart DateTime @unique // Monday UTC
  title     String
  body      String // digest lines joined by \n
  createdAt DateTime @default(now())
}

// ---------- Shuffle engine (Phase 5) ----------
// A reusable, flexible time block the solver reflows around fixed commitments.

model TimeBlock {
  id          String   @id @default(cuid())
  title       String
  rigidity    String   @default("flexible") // flexible | elastic | fluid
  durationMin Int
  minChunkMin Int      @default(30) // elastic: smallest contiguous piece
  energy      String   @default("any") // high | low | any
  days        String? // CSV weekdays 0-6 (null = any day)
  startMin    Int      @default(360) // earliest time-of-day
  endMin      Int      @default(1320) // latest time-of-day
  theme       String?
  priority    Int      @default(100)
  habitId     String? // habit blocks are protected (placed first)
  habit       Habit?   @relation(fields: [habitId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([habitId])
}

model Task {
  id        String    @id @default(cuid())
  title     String
  done      Boolean   @default(false)
  dueDate   DateTime?
  priority  String    @default("normal")
  createdAt DateTime  @default(now())
}

// ---------- Seasons & week templates (Phase 9) ----------
// A Season is a 6–12wk focus window. A WeekTemplate is a saved set of TimeBlock
// specs that can be materialised into real TimeBlock rows ("apply default week").

model Season {
  id        String   @id @default(cuid())
  name      String
  start     DateTime
  end       DateTime
  theme     String?
  goalIds   String? // CSV of Goal ids in focus this season
  valueId   String?
  value     Value?   @relation(fields: [valueId], references: [id], onDelete: SetNull)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([start])
  @@index([valueId])
}

model WeekTemplate {
  id        String   @id @default(cuid())
  name      String
  blocks    String // JSON array of TimeBlock specs
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// ---------- Knowledge garden (Phase 10) ----------
// A local-first cache of references (articles, videos, papers) that can roll up
// to a Value or Goal. Same pattern as CalendarEvent: the app reads this cache;
// external MCP ingest (Drive/PubMed) can populate `raw` later, but manual adds
// work standalone.

model Reference {
  id        String   @id @default(cuid())
  title     String
  source    String? // inferred host/provider, e.g. youtube | spotify | pubmed | web
  url       String?
  note      String?
  valueId   String?
  value     Value?   @relation(fields: [valueId], references: [id], onDelete: SetNull)
  goalId    String?
  goal      Goal?    @relation(fields: [goalId], references: [id], onDelete: SetNull)
  raw       String? // original MCP payload (JSON) when ingested
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([valueId])
  @@index([goalId])
}

// ---------- Habits (Atomic Habits engine — Phase 1) ----------

model Habit {
  id                String     @id @default(cuid())
  name              String
  identityStatement String? // the "this votes for…" line
  type              String     @default("build") // build | break
  cadence           String     @default("daily") // daily | weekly_count | weekdays
  targetCount       Int? // for weekly_count: times per week
  weekdays          String? // for weekdays cadence: CSV of 0-6 (Sun..Sat)
  cue               String? // the 4 laws (optional)
  craving           String?
  response          String?
  reward            String?
  twoMinVersion     String? // the "two-minute rule" starter version
  rewardBundle      String? // temptation bundling: a link/URI paired with this habit (e.g. a playlist)
  archived          Boolean    @default(false)
  sortOrder         Int        @default(0)
  createdAt         DateTime   @default(now())
  goalId            String? // leading indicator for this goal
  goal              Goal?      @relation(fields: [goalId], references: [id], onDelete: SetNull)
  valueId           String? // the identity/value this habit votes for
  value             Value?     @relation(fields: [valueId], references: [id], onDelete: SetNull)
  logs              HabitLog[]
  timeBlocks        TimeBlock[]
  urges             UrgeLog[]
  stackItems        HabitStackItem[]

  @@index([goalId])
  @@index([valueId])
}

// ---------- Habit stacking (Phase 8) ----------

model HabitStack {
  id        String           @id @default(cuid())
  name      String
  cue       String? // the anchor: "After I [cue]…"
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  items     HabitStackItem[]
}

model HabitStackItem {
  id      String     @id @default(cuid())
  stackId String
  stack   HabitStack @relation(fields: [stackId], references: [id], onDelete: Cascade)
  habitId String
  habit   Habit      @relation(fields: [habitId], references: [id], onDelete: Cascade)
  order   Int        @default(0)

  @@unique([stackId, habitId])
  @@index([stackId])
}

// ---------- Break-habit urge log (Phase 7) ----------

model UrgeLog {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  timestamp DateTime @default(now())
  gaveIn    Boolean  @default(false) // true = slipped; false = urge resisted
  intensity Int? // 1-5
  trigger   String?
  note      String?

  @@index([habitId])
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime // normalised to UTC midnight
  status    String   @default("done") // done | partial | skipped
  value     Float? // optional quantified amount (e.g. minutes, reps)
  notes     String?
  createdAt DateTime @default(now())

  @@unique([habitId, date])
  @@index([habitId])
}
