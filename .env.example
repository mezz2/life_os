# Copy this file to .env.local and fill in your own values.
# Both .env and .env.local are gitignored — your secrets stay on your machine.

# SQLite database location (default is fine for local use).
DATABASE_URL="file:./dev.db"

# Optional: enables AI categorisation of unknown merchants + the monthly insight
# narrative. Without it, rule-based categorisation and alerts still work.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=""

# Optional: your name, shown in the dashboard greeting ("Good morning, <name>").
# Leave unset for a plain greeting.
NEXT_PUBLIC_USER_NAME=""

# Optional: Google Calendar two-way sync (Calendar page → Connect / Refresh).
# These are your OAuth *app* credentials; your personal grant (refresh token) is
# stored in the local SQLite DB after you click Connect, never here.
# Setup (one-time, ~10 min):
#   1. https://console.cloud.google.com → create a project.
#   2. APIs & Services → enable "Google Calendar API".
#   3. OAuth consent screen → External → add yourself as a Test user.
#   4. Credentials → Create OAuth client ID → type "Web application".
#   5. Add Authorised redirect URI: http://localhost:3000/api/calendar/auth/callback
#   6. Copy the client ID/secret below. Scope is limited to calendar.events only.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Only change if you run the app on a different host/port.
GOOGLE_REDIRECT_URI="http://localhost:3000/api/calendar/auth/callback"
